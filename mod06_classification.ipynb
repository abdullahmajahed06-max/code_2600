   "outputs": [],
   "source": [
    "# packages\n",
    "import numpy as np \n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.pyplot import subplots\n",
    "import statsmodels.api as sm\n",
    "from ISLP import (load_data, confusion_table)\n",
    "from ISLP.models import (ModelSpec as MS, summarize, contrast)\n",
    "from sklearn.model_selection import train_test_split \n",
    "from sklearn.naive_bayes import GaussianNB\n",
    "from sklearn.neighbors import KNeighborsClassifier\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import RocCurveDisplay, roc_auc_score\n",
    "\n",
    "roc_curve_est = RocCurveDisplay.from_estimator \n",
    "roc_curve_pred = RocCurveDisplay.from_predictions \n",
    "\n",
    "# set seed\n",
    "seed = 5331"
   ]
  },

  {
   "cell_type": "markdown",
   "id": "8205b0af",
   "metadata": {},
   "source": [
    "### We will use the OJ dataset, which contains information about orange juice purchases across different stores."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9c212154",
   "metadata": {},
   "outputs": [],
   "source": [
    "OJ = load_data('OJ')\n",
    "OJ"
   ]
  },

  {
   "cell_type": "markdown",
   "id": "c076ad89",
   "metadata": {},
   "source": [
    "### What are the variables and their types?"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d24390cb",
   "metadata": {},
   "outputs": [],
   "source": [
    "OJ.dtypes"
   ]
  },

  {
   "cell_type": "markdown",
   "id": "0016e739",
   "metadata": {},
   "source": [
    "### We will use all stores other than ID=7 as training data, and Store #7 will be used as test."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5f1eedd3",
   "metadata": {},
   "outputs": [],
   "source": [
    "OJ[\"StoreID\"].value_counts()"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "94daafb2",
   "metadata": {},
   "outputs": [],
   "source": [
    "Train = OJ[OJ['StoreID'] != 7]\n",
    "Train"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2e13fff7",
   "metadata": {},
   "outputs": [],
   "source": [
    "Test = OJ[OJ['StoreID']==7]"
   ]
  },

  {
   "cell_type": "markdown",
   "id": "1ebbdeae",
   "metadata": {},
   "source": [
    "### We will predict whether each customer purchased Citrus Hill or Minute Maid."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4a91fa5a",
   "metadata": {},
   "outputs": [],
   "source": [
    "y_train = Train.Purchase == 'CH'\n",
    "y_test = Test.Purchase == 'CH'"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d1825f92",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train = Train[['WeekofPurchase','PriceCH','PriceMM','DiscCH','DiscMM','SpecialCH','SpecialMM','LoyalCH','SalePriceCH','SalePriceMM','PriceDiff','PctDiscCH','PctDiscMM','ListPriceDiff']]\n",
    "X_test = Test[['WeekofPurchase','PriceCH','PriceMM','DiscCH','DiscMM','SpecialCH','SpecialMM','LoyalCH','SalePriceCH','SalePriceMM','PriceDiff','PctDiscCH','PctDiscMM','ListPriceDiff']]"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4238020c",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train['intercept'] = np.ones(X_train.shape[0])\n",
    "X_test['intercept'] = np.ones(X_test.shape[0])"
   ]
  },

  {
   "cell_type": "markdown",
   "source": ["## Logistic Regression"]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "var_list = ['intercept','LoyalCH','PriceDiff']\n",
    "\n",
    "glm = sm.GLM(y_train,\n",
    "             X_train[var_list],\n",
    "             family=sm.families.Binomial())\n",
    "\n",
    "results = glm.fit()\n",
    "\n",
    "summarize(results)"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "def predict(X, model):\n",
    "    predictions_df = pd.DataFrame(model.get_prediction(X).predicted,\n",
    "                                  columns=['y_hat'],\n",
    "                                  index=X.index)\n",
    "    return predictions_df['y_hat']"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "probs_train=predict(X_train[var_list],results)\n",
    "probs_test=predict(X_test[var_list],results)"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "predictions_train = np.array([True]*len(y_train))\n",
    "predictions_train[probs_train<0.5] = False\n",
    "\n",
    "predictions_test = np.array([True]*len(y_test))\n",
    "predictions_test[probs_test<0.5] = False"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "train_table = confusion_table(predictions_train, y_train)\n",
    "train_table"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "test_table = confusion_table(predictions_test, y_test)\n",
    "test_table"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "false_positive_rate = np.sum((predictions_test == True) & (y_test == False)) / np.sum(y_test == False)\n",
    "print(\"fpr =\",false_positive_rate)\n",
    "\n",
    "false_negative_rate = np.sum((predictions_test == False) & (y_test == True)) / np.sum(y_test == True)\n",
    "print(\"fnr =\",false_negative_rate)"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "var_list.remove('intercept')\n",
    "X_train_array, X_test_array = [np.asarray(X) for X in [X_train[var_list], X_test[var_list]]]"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "best_k = 0\n",
    "num_correct_pred = 0\n",
    "\n",
    "for k in range(1,500):\n",
    "    knn = KNeighborsClassifier(n_neighbors=k)\n",
    "    knn.fit(X_train_array, y_train)\n",
    "    knn_pred = knn.predict(X_test_array)\n",
    "    correct = np.sum(knn_pred == y_test)\n",
    "\n",
    "    if correct > num_correct_pred:\n",
    "        num_correct_pred = correct\n",
    "        best_k = k\n",
    "\n",
    "print(best_k)\n",
    "print(num_correct_pred)"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "knn_opt = KNeighborsClassifier(n_neighbors=best_k)\n",
    "knn_opt.fit(X_train_array, y_train)\n",
    "knn_opt_test = knn_opt.predict(X_test_array)\n",
    "\n",
    "confusion_table(knn_opt_test, y_test)"
   ]
  },

  {
   "cell_type": "markdown",
   "source": [
    "### Of the models that were built in this notebook, which would you choose to implement? Why?\n",
    "\n",
    "I would choose the logistic regression model. It is simple, easy to interpret, and uses only the most important predictors (loyalty and price difference), which helps reduce overfitting. Logistic regression also provides predicted probabilities, which makes it easier to understand the model’s confidence and adjust the classification threshold if needed."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "source": [
    "misclassification_rate = np.sum(y_test == False) / len(y_test)\n",
    "print(misclassification_rate)"
   ]
  }

 ]
}
